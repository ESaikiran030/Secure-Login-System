# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Database Configuration
# Set DB_TYPE to 'sqlite' or 'mysql'
DB_TYPE=sqlite
DATABASE_URL=sqlite:///secure_login.db

# MySQL Configuration (used when DB_TYPE=mysql)
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=secure_login

# Security Settings
SESSION_COOKIE_SECURE=False
PERMANENT_SESSION_LIFETIME=1800
REMEMBER_COOKIE_DURATION=2592000

# Rate Limiting
RATELIMIT_STORAGE_URI=memory://

# Application Settings
APP_NAME=Secure Login System
